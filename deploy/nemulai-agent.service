[Unit]
Description=NemulAI GPU Energy Monitoring Agent
Documentation=https://nemulai.com/docs/agent
After=network-online.target nvidia-persistenced.service
Wants=network-online.target
# Restart if NVML driver is temporarily unavailable (e.g. driver reload)
StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
Type=simple
User=nemulai
Group=nemulai
EnvironmentFile=/etc/nemulai/agent.env
Environment=DATA_DIR=/var/lib/nemulai
Environment=LOG_DIR=/var/log/nemulai

ExecStart=/usr/local/bin/nemulai
ExecReload=/bin/kill -HUP $MAINPID

Restart=on-failure
RestartSec=10s

# Give the agent time to flush on SIGTERM before SIGKILL
TimeoutStopSec=30

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nemulai-agent

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/var/log/nemulai /opt/nemulai-agent/data

[Install]
WantedBy=multi-user.target
