{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "NemulAI GPU monitoring — power, utilization, temperature, energy, and agent health",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "GPU Power Draw",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "nemulai_gpu_power_watts",
          "legendFormat": "GPU {{gpu_index}} ({{gpu_uuid}})",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "watt", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "title": "GPU Utilization",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "nemulai_gpu_utilization_pct",
          "legendFormat": "GPU {{gpu_index}}",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      }
    },
    {
      "title": "GPU Temperature",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "nemulai_gpu_temperature_c",
          "legendFormat": "GPU {{gpu_index}}",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 70, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Cumulative Energy (Joules)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "nemulai_gpu_energy_joules_total",
          "legendFormat": "GPU {{gpu_uuid}}",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "joule" }
      }
    },
    {
      "title": "Phase Decomposition — Tensor Power",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "nemulai_gpu_tensor_power_watts",
          "legendFormat": "GPU {{gpu_index}} tensor",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "nemulai_gpu_fp16_power_watts",
          "legendFormat": "GPU {{gpu_index}} fp16",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "watt" } }
    },
    {
      "title": "Phase Decomposition — Memory & Idle",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "targets": [
        {
          "expr": "nemulai_gpu_memory_power_watts",
          "legendFormat": "GPU {{gpu_index}} memory",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "nemulai_gpu_idle_power_watts",
          "legendFormat": "GPU {{gpu_index}} idle",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "watt" } }
    },
    {
      "title": "Upload Health",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "targets": [
        {
          "expr": "nemulai_upload_success_total",
          "legendFormat": "Success",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "nemulai_upload_failure_total",
          "legendFormat": "Failures",
          "datasource": "${DS_PROMETHEUS}"
        }
      ]
    },
    {
      "title": "Buffer & WAL",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "nemulai_buffer_size",
          "legendFormat": "Buffer",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "nemulai_wal_entries_pending",
          "legendFormat": "WAL pending",
          "datasource": "${DS_PROMETHEUS}"
        },
        {
          "expr": "nemulai_wal_size_bytes",
          "legendFormat": "WAL bytes",
          "datasource": "${DS_PROMETHEUS}"
        }
      ]
    },
    {
      "title": "Attribution Confidence",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "nemulai_attribution_confidence",
          "legendFormat": "GPU {{gpu_index}} / {{job_id}} ({{method}})",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 1, "unit": "percentunit" }
      }
    },
    {
      "title": "Agent Info",
      "type": "table",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "expr": "nemulai_agent_info",
          "format": "table",
          "instant": true,
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "pattern": "hostname|version|mode|Value" } } }
      ]
    },
    {
      "title": "Agent Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "nemulai_agent_uptime_seconds",
          "legendFormat": "Uptime",
          "datasource": "${DS_PROMETHEUS}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["nemulai", "gpu", "nvidia"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "NemulAI — GPU Overview",
  "uid": "nemulai-gpu-overview",
  "version": 1
}
