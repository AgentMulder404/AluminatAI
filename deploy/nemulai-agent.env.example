# NemulAI GPU Agent — Environment Configuration
# Copy to /etc/nemulai/agent.env and fill in your values.
# All variables are optional except ALUMINATAI_API_KEY.
#
# Get your API key at https://nemulai.com/dashboard

# ── Required ──────────────────────────────────────────────────────────────────

ALUMINATAI_API_KEY=alum_your_key_here

# ── API ───────────────────────────────────────────────────────────────────────

# Ingest endpoint (default: https://nemulai.com/v1/metrics/ingest)
# Override for self-hosted deployments.
# ALUMINATAI_API_ENDPOINT=https://nemulai.com/v1/metrics/ingest

# ── Sampling & Upload ─────────────────────────────────────────────────────────

# Seconds between NVML reads (default: 5.0)
# SAMPLE_INTERVAL=5.0

# Seconds between metric flushes to the API (default: 60)
# UPLOAD_INTERVAL=60

# Metrics per HTTP request (default: 100)
# UPLOAD_BATCH_SIZE=100

# Max upload retries before writing to WAL (default: 5)
# UPLOAD_MAX_RETRIES=5

# Max seconds between retries, exponential backoff cap (default: 60)
# UPLOAD_MAX_RETRY_DELAY=60

# ── WAL (Write-Ahead Log) ─────────────────────────────────────────────────────
# The WAL buffers metrics locally during API outages and replays on reconnect.

# Directory for WAL and other persistent data (default: ./data)
# DATA_DIR=/var/lib/nemulai

# Max age of WAL entries before they are discarded (default: 24 hours)
# WAL_MAX_AGE_HOURS=24

# Max WAL size in MB before oldest entries are pruned (default: 512)
# WAL_MAX_MB=512

# ── Job Attribution ───────────────────────────────────────────────────────────

# Tag all workloads from this machine with a team name
# ALUMINATAI_TEAM=nlp-team

# Tag all workloads with a model name
# ALUMINATAI_MODEL=llama3-finetune

# Path to a JSON/YAML attribution rules file for custom job mapping
# ALUMINATAI_ATTRIBUTION_CONFIG=/etc/nemulai/attribution.json

# Comma-separated list of trusted Unix UIDs for process attribution
# ALUMINATAI_TRUSTED_UIDS=1000,1001,1002

# Seconds between scheduler polls (Kubernetes, Slurm, Run:ai) (default: 30)
# SCHEDULER_POLL_INTERVAL=30

# ── Heartbeat ─────────────────────────────────────────────────────────────────

# Seconds between agent heartbeats to the dashboard (default: 300)
# HEARTBEAT_INTERVAL=300

# ── Prometheus Metrics ────────────────────────────────────────────────────────

# Port to expose Prometheus /metrics endpoint (default: 9100, 0 = disabled)
# METRICS_PORT=9100

# Bind address for Prometheus server (default: 0.0.0.0)
# METRICS_BIND_HOST=0.0.0.0

# Basic auth for Prometheus scrape endpoint: "user:password" (default: none)
# METRICS_BASIC_AUTH=prometheus:secret

# ── TLS / Proxy ───────────────────────────────────────────────────────────────

# HTTP proxy for outbound API calls
# HTTPS_PROXY=http://proxy.corp.example.com:8080

# Path to a custom CA bundle PEM file (for corporate/self-signed CAs)
# ALUMINATAI_CA_BUNDLE=/etc/ssl/certs/corp-ca.pem

# mTLS client certificate and key (for mutual TLS with private ingest endpoints)
# ALUMINATAI_CLIENT_CERT=/etc/nemulai/client.crt
# ALUMINATAI_CLIENT_KEY=/etc/nemulai/client.key

# ── Run Modes ─────────────────────────────────────────────────────────────────

# Collect and attribute metrics but skip all uploads and WAL writes (default: 0)
# DRY_RUN=0

# Disable cloud uploads entirely; serve Prometheus metrics only (default: 0)
# PROMETHEUS_ONLY=0

# Write to WAL only; no HTTP uploads (survives long outages) (default: 0)
# OFFLINE_MODE=0

# ── Carbon Tracking ───────────────────────────────────────────────────────────

# Electricity Maps API key for real-time carbon intensity data.
# Get your key at https://www.electricitymaps.com/free-tier
# Required server-side (Vercel env) for the hourly carbon-refresh cron.
# ELECTRICITY_MAPS_API_KEY=your_key_here

# Grid zone code for this deployment — used to stamp CO₂ intensity at ingest time.
# Find your zone at https://www.electricitymaps.com/map
# Examples: US-CAL-CISO  US-MIDA-PJM  DE  FR  GB  SE  AU-NSW
# ALUMINATAI_GRID_ZONE=US-CAL-CISO

# ── DCGM Phase Decomposition ──────────────────────────────────────────────────
# Requires NVIDIA DCGM (datacenter-gpu-manager) installed and nv-hostengine running.
# When enabled, the agent uses DCGM profiling counters (tensor/FP16/DRAM activity)
# to decompose total GPU power into per-phase Prometheus gauges:
#   nemulai_gpu_tensor_power_watts, nemulai_gpu_fp16_power_watts,
#   nemulai_gpu_memory_power_watts, nemulai_gpu_idle_power_watts
# Falls back to NVML utilization rates automatically if DCGM is unavailable.
# Set to 0 to disable entirely.
# DCGM_ENABLED=1

# Per-GPU power decomposition coefficients (relative weights, stored as JSON).
# Auto-generated by calibration; edit manually to tune for your GPU fleet.
# Path: ~/.config/nemulai/dcgm_coefficients.json

# ── Idle Baseline + Warmup ────────────────────────────────────────────────────
# Seconds to sample idle GPU power on startup (all GPUs must be idle).
# Set to 0 to disable calibration. Baselines cached 24 h.
# IDLE_BASELINE_WINDOW=30

# Seconds of samples discarded from uploads after agent start (warm-up transients).
# Prometheus still shows live data during this window.
# WARMUP_DISCARD_SECONDS=45

# ── Benchmarking ──────────────────────────────────────────────────────────────

# HMAC-SHA256 salt for anonymous user ID hashing in benchmark submissions.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Required to enable /api/benchmarks/submit (returns 500 if unset).
# BENCHMARK_SALT=your_32_byte_hex_salt_here

# ── Logging ───────────────────────────────────────────────────────────────────

# Log verbosity: DEBUG, INFO, WARNING, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Log format: "text" (human-readable) or "json" (for ELK/Grafana Loki)
# LOG_FORMAT=text

# Directory for log files (default: ./logs)
# LOG_DIR=/var/log/nemulai
